# ── Credentials ──────────────────────────────────────────────────────────────
# Copy .env.example → .env and fill in your values; never commit .env
ngnt-geiger-dockerized/.env

# ── Runtime volume data (wiped on reset) ─────────────────────────────────────
ngnt-geiger-dockerized/volumes/mariadb/*
!ngnt-geiger-dockerized/volumes/mariadb/.gitkeep

ngnt-geiger-dockerized/volumes/mosquitto/data/*
!ngnt-geiger-dockerized/volumes/mosquitto/data/.gitkeep


# ── Log files ────────────────────────────────────────────────────────────────
ngnt-geiger-dockerized/log/mosquitto/*.log
!ngnt-geiger-dockerized/log/mosquitto/.gitkeep
