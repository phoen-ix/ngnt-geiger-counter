# Copy this file to .env and fill in your own values before running docker compose.
#   cp .env.example .env

# ── Docker image versions ────────────────────────────────────────────────────
DOCKER_IMAGE_MARIADB_TAG=11.4.10
DOCKER_IMAGE_MOSQUITTO_TAG=2.1.2-alpine


# ── Exposed ports ────────────────────────────────────────────────────────────
# Web dashboard:   http://<your-server>:1880
# MQTT broker:     <your-server>:2883  (plain)
#                  <your-server>:8883  (TLS)
FLASK_PORTS=1880:8000
MOSQUITTO_PORTS=2883:1883
MOSQUITTO_PORTS_TLS=8883:8883


# ── Flask ────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-random-hex-string
SITE_NAME=NGNT Geiger Counter


# ── MariaDB ──────────────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=change-me-root-password
MARIADB_USER=mariadb_usr
MARIADB_PASSWORD=change-me-user-password
MARIADB_DATABASE=ngnt-geigercounter
MARIADB_TIMEZONE=UTC


# ── MQTT users ───────────────────────────────────────────────────────────────
# pythonUSR  → used internally by the Python subscriber container
# Device credentials are provisioned via the web UI (no env vars needed)
MQTT_PYTHON_USER=pythonUSR
MQTT_PYTHON_USERPW=change-me-python-password


# ── Internal Docker network ───────────────────────────────────────────────────
# Subnet: <IPV4_NETWORK>.0/24
#   flask       .10
#   mariadb     .20
#   mosquitto   .30
#   subscriber  .40
IPV4_NETWORK=172.18.1
